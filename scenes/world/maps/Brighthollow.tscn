[node name="Mira" parent="." instance=ExtResource("4_npc")]
npc_name = "Sister Mira"
grid_position = Vector2i(15, 6)
lines = PackedStringArray("My sister Aila went into the tomb three nights ago. She hasn't come back.", "The Plague's roots are there, deeper than any of us reckoned. The Hollow King has woken.", "I will go with you, if you'll have me. Lay him to rest, and perhaps Aila too.", "(Sister Mira has joined the party!)")
lines_after_first = PackedStringArray("The chapel's bell rings every hour I'm not in it. We should go — soon.")
conversation_flag = &"mira_joined"
recruit_actor_id = &"mira"
sprite_texture = ExtResource("8_mira_tex")
