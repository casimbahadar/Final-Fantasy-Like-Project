[node name="Shopkeeper" parent="." instance=ExtResource("4_npc")]
npc_name = "Wenn the Stocker"
grid_position = Vector2i(4, 6)
lines = PackedStringArray("Word of the Crystal Heart's awakening reached us this morning.", "I've ordered up better gear. The road ahead is rougher than the cave.", "Take a look — and stay sharp.")
shop_inventory = Array[StringName]([&"hi_potion", &"ether", &"antidote", &"eye_drops", &"echo_herb", &"soft", &"phoenix_down", &"iron_sword", &"silver_wand", &"chain_mail", &"silk_robe", &"ribbon"])
sprite_texture = ExtResource("5_shop_tex")

[node name="Innkeeper" parent="." instance=ExtResource("4_npc")]
npc_name = "Tomas of the Hollow"
grid_position = Vector2i(4, 11)
lines = PackedStringArray("Brighthollow's been a way-stop since the kingdom's first roads were laid.", "A bed costs 50 gold — no haggling. Heals you to full.")
inn_cost = 50
sprite_texture = ExtResource("6_inn_tex")

[node name="Villager" parent="." instance=ExtResource("4_npc")]
npc_name = "Old Maren"
grid_position = Vector2i(15, 11)
lines = PackedStringArray("They say the King's tomb breathes again. Hollow as an empty barrel and twice as cold.", "If you mean to go in there, take Sister Mira from the chapel. She has cause.")
sprite_texture = ExtResource("7_villager_tex")
quest_required_flag = &"mira_joined"
quest_accept_flag = &"maren_quest_accepted"
quest_required_kill_enemy = &"wraith"
quest_required_kill_count = 6
quest_reward_flag = &"maren_quest_done"
quest_reward_item = &"ribbon"
quest_reward_item_count = 1
quest_reward_gold = 800
quest_offer_lines = PackedStringArray("My husband stayed in the temple too long, the night before he died. The wraiths there speak in his voice now.", "If you make six of them silent, I'll give you the ribbon I was going to bury him in. He doesn't need it. I'd like someone alive to wear it.")
quest_progress_lines = PackedStringArray("Six wraiths. They speak in voices we should not hear.")
quest_complete_lines = PackedStringArray("Six. Thank you, child.", "Take the ribbon. He'd have liked you.")
quest_done_lines = PackedStringArray("The temple is quieter now. Thank you.")

[node name="InnkeeperQuest" parent="." instance=ExtResource("4_npc")]
npc_name = "Tomas of the Hollow"
grid_position = Vector2i(7, 11)
lines = PackedStringArray("The cellar's run dry on tinctures. Nothing for fevers, nothing for the children with the cough.")
sprite_texture = ExtResource("6_inn_tex")
quest_required_flag = &"crystal_wraith_defeated"
quest_accept_flag = &"tomas_quest_accepted"
quest_required_item = &"ether"
quest_required_item_count = 5
quest_reward_flag = &"tomas_quest_done"
quest_reward_item = &"hi_potion"
quest_reward_item_count = 8
quest_reward_gold = 600
quest_offer_lines = PackedStringArray("I'm short on tinctures. I can't trade for them — the alchemists are all in Brighthollow, and so is the road south. But ethers from the wood will do, in a pinch.", "Five Ethers, and I'll give you eight Hi-Potions out of my own stash and six hundred gold for the trouble.")
quest_progress_lines = PackedStringArray("Five Ethers when you find them. The cough's getting bad in the back rooms.")
quest_complete_lines = PackedStringArray("Five — thank you. Hi-Potions are yours, and the gold.")
quest_done_lines = PackedStringArray("The children sleep again. Stay the night any time, on the house.")

[node name="FatherCinric" parent="." instance=ExtResource("4_npc")]
npc_name = "Father Cinric"
grid_position = Vector2i(9, 6)
lines = PackedStringArray("Brighthollow's chapel is the kingdom's last whole one. We light the lamps every dusk, in case any of you make it home.")
sprite_texture = ExtResource("7_villager_tex")
quest_required_flag = &"crystal_wraith_defeated"
quest_accept_flag = &"cinric_quest_accepted"
quest_objective_flag = &"cellar_warden_defeated"
quest_required_item = &"votive_chime"
quest_required_item_count = 1
quest_reward_flag = &"cinric_quest_done"
quest_reward_item = &"cleric_circlet"
quest_reward_item_count = 1
quest_reward_gold = 800
quest_unlock_flag = &"cinric_blessing"
quest_offer_lines = PackedStringArray("Stay a moment. There is a thing I must ask.", "Beneath the Plaza chapel lies an old under-sanctum, flooded years ago. Lately the bell rings on its own. Lately people who go down do not come back up.", "I cannot leave my post. But on its altar there is a votive chime that has rung since the kingdom was founded. If you can bring it to me — and silence whatever has settled below — I will see Auren bless you for it.")
quest_progress_lines = PackedStringArray("The chime, child. From the cellar's altar. And whatever guards it — silence it.", "Be careful below.")
quest_complete_lines = PackedStringArray("...you brought the chime. And the warden no longer rings the bell.", "Then accept this circlet. And carry the chapel's blessing with you, wherever the road takes you next.")
quest_done_lines = PackedStringArray("Walk softly, but walk forward. The chapel remembers you.")

[node name="BountyClerk" parent="." instance=ExtResource("4_npc")]
npc_name = "Bounty Clerk Edda"
grid_position = Vector2i(15, 7)
lines = PackedStringArray("Brighthollow's bounty office. We pay coin for kills the kingdom can't afford to forget.", "Garrick of the Plaza handles the small bounties. Bring me proof of larger work — say, a dozen forest wisps, or a dozen drowned sailors — and I'll pay what they're worth.", "(See Garrick in the Plaza for the slime contract.)")
sprite_texture = ExtResource("7_villager_tex")
quest_required_flag = &"hollow_king_defeated"
quest_accept_flag = &"edda_bounty_accepted"
quest_required_kill_enemy = &"forest_wisp"
quest_required_kill_count = 8
quest_reward_flag = &"edda_bounty_done"
quest_reward_item = &"phoenix_down"
quest_reward_item_count = 3
quest_reward_gold = 1200
quest_unlock_flag = &"bounty_pit_unlocked"
quest_offer_lines = PackedStringArray("New posting. Eight forest wisps, north of the Whispering Wood — they're spooking the trade caravans bad enough to choke the road.", "Bring me eight kills and I'll cover three Phoenix Downs out of the chapel stores, and twelve hundred gold besides.")
quest_progress_lines = PackedStringArray("Eight forest wisps. The road's still choked.")
quest_complete_lines = PackedStringArray("Eight on the dot. The caravans will breathe easier.", "Three Phoenix Downs and twelve hundred. Spend it on something hard-edged.")
quest_done_lines = PackedStringArray("Bounty's settled. Check back if you need a sterner test — the office runs a five-wave bounty pit east of the chapel for any with a strong stomach.")

