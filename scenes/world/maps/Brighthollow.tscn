[ext_resource type="Script" path="res://scripts/world/WarpTrigger.gd" id="3_warp"]
[ext_resource type="PackedScene" path="res://scenes/world/NPC.tscn" id="4_npc"]
[ext_resource type="Texture2D" path="res://assets/sprites/placeholder/npc_shopkeeper.svg" id="5_shop_tex"]
[ext_resource type="Texture2D" path="res://assets/sprites/placeholder/npc_innkeeper.svg" id="6_inn_tex"]
[ext_resource type="Texture2D" path="res://assets/sprites/placeholder/npc_villager.svg" id="7_villager_tex"]
[ext_resource type="Texture2D" path="res://assets/sprites/placeholder/player_cleric.svg" id="8_mira_tex"]
[ext_resource type="Script" path="res://scripts/world/EndingTrigger.gd" id="9_story"]

