map_id = &"sunken_cellar"

[node name="SpawnFromPlaza" type="Node2D" parent="."]
script = ExtResource("2_spawn")
spawn_id = &"from_plaza"
grid_position = Vector2i(9, 2)
facing = 0

[node name="ExitToPlaza" type="Node2D" parent="."]
script = ExtResource("3_warp")
grid_position = Vector2i(8, 1)
grid_size = Vector2i(2, 1)
target_map_id = &"plaza"
target_spawn_id = &"from_cellar"

[node name="ChestEther" parent="." instance=ExtResource("5_chest")]
chest_id = &"cellar_ether"
grid_position = Vector2i(2, 5)
item_id = &"ether"
