[node name="ChestPhoenix" parent="." instance=ExtResource("5_chest")]
chest_id = &"cellar_phoenix"
grid_position = Vector2i(17, 5)
item_id = &"phoenix_down"
item_count = 2

[node name="ChestPendant" parent="." instance=ExtResource("5_chest")]
chest_id = &"cellar_chime"
grid_position = Vector2i(9, 9)
item_id = &"votive_chime"
item_count = 1
sets_flag = &"votive_chime_found"

[node name="WardenTrigger" type="Node2D" parent="."]
script = ExtResource("4_encounter")
grid_position = Vector2i(9, 6)
troop_id = &"cellar_warden_boss"
defeated_flag = &"cellar_warden_defeated"
intro_lines = PackedStringArray("Past the flooded steps, the cellar widens into a forgotten shrine.", "A tall, hollow-faced figure rises from the altar. Twin red embers open where eyes should be.", "\"You came down to the under-sanctum. You came below the bell. By the old rite, you must answer for it.\"", "It lifts a cracked staff, and the cellar dims.")
intro_speaker = "Cellar Warden"
