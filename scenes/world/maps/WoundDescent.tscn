map_id = &"wound_descent"

[node name="SpawnFromCourt" type="Node2D" parent="."]
script = ExtResource("2_spawn")
spawn_id = &"from_court"
grid_position = Vector2i(9, 12)
facing = 3

[node name="SpawnFromWound" type="Node2D" parent="."]
script = ExtResource("2_spawn")
spawn_id = &"from_wound"
grid_position = Vector2i(9, 2)
facing = 0

[node name="ExitToCourt" type="Node2D" parent="."]
script = ExtResource("3_warp")
grid_position = Vector2i(8, 12)
grid_size = Vector2i(2, 1)
target_map_id = &"hollow_court"
target_spawn_id = &"from_descent"

[node name="ExitToWound" type="Node2D" parent="."]
script = ExtResource("3_warp")
grid_position = Vector2i(8, 1)
grid_size = Vector2i(2, 1)
target_map_id = &"world_wound"
target_spawn_id = &"from_court"
requires_flag = &"hollow_twin_defeated"

[node name="ChestCrystalEdge" parent="." instance=ExtResource("5_chest")]
chest_id = &"descent_crystal_edge"
grid_position = Vector2i(2, 5)
item_id = &"crystal_edge"
item_count = 1

[node name="ChestPhoenix" parent="." instance=ExtResource("5_chest")]
chest_id = &"descent_phoenix"
grid_position = Vector2i(17, 5)
item_id = &"phoenix_down"
item_count = 3

[node name="HollowTwinTrigger" type="Node2D" parent="."]
script = ExtResource("4_encounter")
grid_position = Vector2i(9, 5)
troop_id = &"hollow_twin_mini"
defeated_flag = &"hollow_twin_defeated"
intro_lines = PackedStringArray("The wound widens. The walls have stopped being walls — they are mirrors of unmade rock.", "From one of them, a figure in your own armor steps out, with your sword in its hand.", "Aldric stops still. \"...is that me?\"", "It speaks in his voice. Almost. \"You. Or what you'd be without the others. Step aside. I'll finish what I started.\"")
intro_speaker = "Hollow Aldric"
