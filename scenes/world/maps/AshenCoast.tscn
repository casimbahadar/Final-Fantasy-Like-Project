[node name="ChoirTrigger" type="Node2D" parent="."]
script = ExtResource("3_encounter")
grid_position = Vector2i(9, 5)
troop_id = &"drowned_choir_boss"
defeated_flag = &"drowned_choir_defeated"
intro_lines = PackedStringArray("Black water laps at black sand. Across it, voices rise — a hundred voices, none alive.", "A pillar of bound corpses lifts itself from the surf. Its many heads sing in a single tongue you almost understand.", "\"...the seal is broken... the seal is broken... thank you, sweet things, for breaking the seal...\"", "(The chapter 4 ending was a lie. Something the Plague was holding back has begun to wake.)")
intro_speaker = "Drowned Choir"

[node name="HollowDoor" type="Node2D" parent="."]
script = ExtResource("4_story")
grid_position = Vector2i(9, 3)
requires_flag = &"drowned_choir_defeated"
sets_flag = &"chapter_5_complete"
warp_target_map = &"cinder_marsh"
warp_target_spawn = &"from_coast"
speaker = "Tessera"
lines = PackedStringArray("As the Choir collapses, a different song rises — older, slower, and very far away.", "Tessera turns north. \"That's coming from Auren proper. The old Royal Capital. We never went there because no one's gone there in a hundred years.\"", "Mira says, very quietly: \"The Plague was a lid. We took the lid off.\"", "Aldric stares north. \"Then we go to the lid's source.\"", "(The party heads inland, toward the Hollow Court.)")
lines_locked = PackedStringArray("The water is too deep. Too cold. Too many voices.")
