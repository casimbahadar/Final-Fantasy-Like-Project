intro_lines = PackedStringArray("Between the cliffs and the sea hangs a chain of stones, kept aloft by old wind-magic that hums for no one anymore.", "On the highest island a figure waits — robed in vapor, faceless, singing.", "It sings in the language Auren spoke before the kingdom was named. Tessera goes very still.", "\"...go back, child. The ones who came after broke the seal. Go back and unlearn knowing me.\"", "Lyra, gently: \"We came forward. Forgive us.\"")
intro_speaker = "The Wind That Sings"
