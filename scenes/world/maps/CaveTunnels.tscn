[node name="SentinelTrigger" type="Node2D" parent="."]
script = ExtResource("4_encounter")
grid_position = Vector2i(9, 5)
troop_id = &"crystal_sentinel_mini"
defeated_flag = &"crystal_sentinel_defeated"
intro_lines = PackedStringArray("In a wider chamber, sealed crystal-shards drift unnaturally — a half-formed thing taking shape from the cave walls.", "It pulses, then resolves into a vaguely person-shaped sculpture. \"This place is mine. The Heart's voice forbade visitors. The Heart's voice... has not spoken for a long while.\"", "It steps forward, and the air sings.")
intro_speaker = "Crystal Sentinel"
