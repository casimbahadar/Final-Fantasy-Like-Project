[node name="HollowKing" type="Node2D" parent="."]
script = ExtResource("4_encounter")
grid_position = Vector2i(9, 5)
troop_id = &"hollow_king_boss"
defeated_flag = &"hollow_king_defeated"
intro_lines = PackedStringArray("On a throne of bone-white stone sits the long-dead king of Auren.", "He raises his head as you enter. His eyes are two pits of cold green light.", "\"You found me. The Heart found me. I have been waiting so long...\"", "\"Then come. Come and lay your sovereign down.\"")
intro_speaker = "The Hollow King"

[node name="Aila" type="Node2D" parent="."]
script = ExtResource("5_story")
grid_position = Vector2i(9, 3)
requires_flag = &"hollow_king_defeated"
sets_flag = &"aila_found"
warp_target_map = &"mountain_pass"
warp_target_spawn = &"from_temple"
speaker = "Sister Mira"
lines = PackedStringArray("Behind the throne, a small figure curls — pale, breathing, alive.", "Mira drops to her knees. \"Aila. Aila, I have you. I have you.\"", "Aila's eyes flutter open. She speaks, but her voice carries something older than her years —", "\"...the Plague had three roots. You've cut two. The third is in the Whispering above the world.\"", "Mira looks up at you, fierce. \"Then we go up.\"", "Aila pushes a small charm into your hand — a sliver of cracked crystal — and points east, where the cliffs rise into cloud.", "(The party heads for the Mountain Pass.)")
lines_locked = PackedStringArray("A small figure stirs in the shadows behind the throne — but it cannot be reached while the King yet lives.")
