[node name="PlagueTrigger" type="Node2D" parent="."]
script = ExtResource("3_encounter")
grid_position = Vector2i(9, 5)
troop_id = &"first_plague_boss"
defeated_flag = &"first_plague_defeated"
intro_lines = PackedStringArray("The wound opens beneath you and goes on, and on, and on.", "At the bottom — at the deepest, last bottom — something with too many eyes lifts itself toward you.", "It speaks with the voice of the Wraith, and the Hollow King, and the Stormwyrm, and the Choir.", "\"You broke me into pieces and you killed each piece. Charming. Now meet the source. There is no breaking it. There is only feeding it, or being fed.\"", "Mira whispers, voice steady: \"There's a third option.\"")
intro_speaker = "The First Plague"

[node name="ToSurface" type="Node2D" parent="."]
script = ExtResource("4_story")
grid_position = Vector2i(9, 3)
requires_flag = &"first_plague_defeated"
sets_flag = &"chapter_7_complete"
warp_target_map = &"sovereign_arena"
warp_target_spawn = &"from_wound"
speaker = "Aldric"
lines = PackedStringArray("As the First Plague unspools, what is left is a single, very small voice — a child's voice, almost.", "\"...thank you. Tell him. Tell him I am tired.\"", "Aldric closes his eyes a long moment. \"Him?\"", "Tessera, looking up: \"Someone is waiting for us at the top of the wound.\"", "(The party climbs back to the surface — to a place they did not put on any map.)")
lines_locked = PackedStringArray("Below you, the wound goes on. There is no upward path until the source is dealt with.")
