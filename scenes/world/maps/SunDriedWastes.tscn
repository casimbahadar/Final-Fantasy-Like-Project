[node name="MirageKingTrigger" type="Node2D" parent="."]
script = ExtResource("4_encounter")
grid_position = Vector2i(9, 6)
troop_id = &"mirage_king_boss"
defeated_flag = &"mirage_king_defeated"
intro_lines = PackedStringArray("The wastes shimmer. The wastes shimmer harder. The wastes shimmer until something is standing inside the shimmer.", "A figure in faded gold robes, sun-haloed, speaking in three voices.", "\"Travellers. The desert remembers what the kingdom forgot. Sit a while in my court — sit, please, sit.\"", "Mira's hand tightens on her stave. \"This isn't a king. It's the heat itself wearing a crown.\"")
intro_speaker = "The Mirage King"
