grid_position = Vector2i(8, 1)
grid_size = Vector2i(2, 1)
target_map_id = &"temple_antechamber"
target_spawn_id = &"from_wastes"
requires_flag = &"mirage_king_defeated"

[node name="ChestBlade" parent="." instance=ExtResource("5_chest")]
chest_id = &"wastes_sandblasted_blade"
