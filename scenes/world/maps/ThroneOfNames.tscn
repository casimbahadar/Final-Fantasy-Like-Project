[node name="AurenFirstTrigger" type="Node2D" parent="."]
script = ExtResource("4_encounter")
grid_position = Vector2i(9, 6)
troop_id = &"auren_first_boss"
defeated_flag = &"auren_first_defeated"
intro_lines = PackedStringArray("The throne room is older than any throne room you have ever seen. The walls are not stone — they are names, layered.", "On the throne sits a young man. He is not crowned. He is too young to be crowned.", "\"I am the kingdom's first king,\" he says, very calmly. \"I have not been crowned yet. I am about to be. After I am crowned I will become the Sovereign Eternal, and after that the Plague, and after that what your friends ended.\"", "He stands. \"You came back through time, somehow. You came to stop me before I begin. Try.\"")
intro_speaker = "Auren the First"

[node name="FirstCrownReward" type="Node2D" parent="."]
script = ExtResource("5_reward")
grid_position = Vector2i(9, 2)
requires_flag = &"auren_first_defeated"
sets_flag = &"true_ending_unlocked"
grants_item = &"first_crown"
grants_item_count = 1
grants_gold = 30000
speaker = "Lyra"
lines = PackedStringArray("On the throne, where the young man was, sits only a crown. Plain, light, unbearably old.", "Lyra picks it up. \"He never wore it. He died before he was crowned. We... we made the past where he didn't.\"", "Aldric, very softly: \"Then there is no kingdom of Auren. There never was.\"", "Lyra: \"Or there is one we have to make.\"", "(Got Auren's First Crown! +30000 gold.)")
lines_locked = PackedStringArray("The throne is silent. The young king watches.")
