[node name="ChestPhoenix" parent="." instance=ExtResource("6_chest")]
chest_id = &"tower_phoenix"
grid_position = Vector2i(17, 9)
item_id = &"phoenix_down"
item_count = 6

[node name="ChestSunBlade" parent="." instance=ExtResource("6_chest")]
chest_id = &"tower_sun_blade"
grid_position = Vector2i(2, 5)
item_id = &"sun_blade"
item_count = 1

[node name="Floor1" type="Node2D" parent="."]
script = ExtResource("4_encounter")
grid_position = Vector2i(9, 10)
troop_id = &"tomb_mix"
defeated_flag = &"glass_tower_floor_1"
intro_lines = PackedStringArray("The first floor is glass and bone. Three figures step out of the walls themselves — kingdom-old, blade-clutching.")
intro_speaker = "Tower Echoes"

[node name="Floor2" type="Node2D" parent="."]
script = ExtResource("4_encounter")
grid_position = Vector2i(9, 7)
troop_id = &"crypt_lord_boss"
defeated_flag = &"glass_tower_floor_2"
intro_lines = PackedStringArray("Past the second stair the air goes funeral-cold. The Crypt Lord has come up from below — twin scepters and a face like an old door.", "\"You came here because you ended me. I came here because you didn't stay ended.\"")
intro_speaker = "Crypt Lord (Echo)"

[node name="Floor3" type="Node2D" parent="."]
script = ExtResource("4_encounter")
grid_position = Vector2i(9, 5)
troop_id = &"hollow_lyra_boss"
defeated_flag = &"glass_tower_floor_3"
intro_lines = PackedStringArray("The Tower's middle floor is mirrored from wall to ceiling. Lyra walks in front of every reflection, including her own.", "\"You let me die down there. Try it again, with one less of you up here.\"")
intro_speaker = "Hollow Lyra (Echo)"

[node name="Floor4" type="Node2D" parent="."]
script = ExtResource("4_encounter")
grid_position = Vector2i(9, 3)
troop_id = &"sovereign_reborn_boss"
defeated_flag = &"glass_tower_floor_4"
intro_lines = PackedStringArray("The fourth floor opens onto a sky that should not be. The Sovereign Reborn waits at the centre, glass crown reforged.", "\"I keep being born. Be patient with me.\"")
intro_speaker = "Sovereign Reborn (Echo)"

[node name="ApexFight" type="Node2D" parent="."]
script = ExtResource("4_encounter")
grid_position = Vector2i(9, 1)
troop_id = &"first_day_boss"
defeated_flag = &"first_day_defeated"
intro_lines = PackedStringArray("The Tower's apex opens onto open sky.", "At the centre, a figure of golden bands and a sun-disc head stands very, very still.", "\"I am the day Auren was founded. I have stood at the top of this tower since then, untouched. You came up the stairs.\"", "\"I will go down them, one way or another.\"", "Lyra, very softly: \"It's the kingdom itself.\"", "Aldric: \"Then we put the kingdom down. Cleanly.\"")
intro_speaker = "The First Day"

[node name="GlassCrownReward" type="Node2D" parent="."]
script = ExtResource("5_reward")
grid_position = Vector2i(17, 1)
requires_flag = &"first_day_defeated"
sets_flag = &"glass_crown_claimed"
grants_item = &"glass_crown_item"
grants_item_count = 1
grants_gold = 12000
speaker = "Lyra"
lines = PackedStringArray("Where the First Day stood, a crown lies on bare floor. It is heavier than it looks. It is lighter than it should be.", "Lyra picks it up. \"...he was carrying it the whole time. He was the carrying.\"", "Aldric closes her hands around it. \"Then so are we, now.\"", "(Got Glass Crown! +12000 gold.)")
lines_locked = PackedStringArray("Glass and bone. The Tower keeps its silence — for now.")
