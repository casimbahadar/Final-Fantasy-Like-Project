facing = 3

[node name="ExitToPlaza" type="Node2D" parent="."]
script = ExtResource("3_warp")
grid_position = Vector2i(8, 12)
grid_size = Vector2i(2, 1)
target_map_id = &"plaza"
target_spawn_id = &"from_tower"

[node name="ChestEthers" parent="." instance=ExtResource("6_chest")]
chest_id = &"tower_ethers"
grid_position = Vector2i(2, 9)
item_id = &"ether"
