[node name="LastQueenTrigger" type="Node2D" parent="."]
script = ExtResource("4_encounter")
grid_position = Vector2i(9, 7)
troop_id = &"last_queen_boss"
defeated_flag = &"last_queen_defeated"
intro_lines = PackedStringArray("Beneath the Pretender's throne, generations of Auren queens lie undisturbed in stone — except one.", "Her sarcophagus is split. Inside it she sits, in finery still rich, eyes empty and crown crooked.", "\"My husband is dead. My grandchildren are dead. My country is dead. I am told I have not noticed.\"", "Mira lifts her stave gently. \"Then let us tell you, your majesty.\"")
intro_speaker = "The Last Queen"
