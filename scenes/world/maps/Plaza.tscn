facing = 3

[node name="SpawnSouthReturn" type="Node2D" parent="."]
script = ExtResource("2_spawn")
spawn_id = &"south_return"
grid_position = Vector2i(10, 11)
facing = 3

[node name="Sage" parent="." instance=ExtResource("4_npc")]
npc_name = "Old Sage"
grid_position = Vector2i(10, 4)
lines = PackedStringArray("So you are the ones the prophecy spoke of...", "Aldric, Lyra — the Crystal Plague spreads each day.", "South of here, beyond the road, lies a cavern where a wraith has nested at the heart of the crystal.", "End it, and the Plague ends with it.")
lines_after_first = PackedStringArray("The wraith waits. Time is short.")
conversation_flag = &"talked_to_sage"
sprite_texture = ExtResource("5_sage_tex")

[node name="Innkeeper" parent="." instance=ExtResource("4_npc")]
npc_name = "Brenna"
grid_position = Vector2i(4, 6)
lines = PackedStringArray("Welcome to the Wandering Boar Inn. A bed for 20 gold restores all HP and MP.")
inn_cost = 20
sprite_texture = ExtResource("6_inn_tex")
quest_required_flag = &"talked_to_sage"
quest_accept_flag = &"brenna_quest_accepted"
quest_objective_flag = &"brenna_locket_found"
quest_required_item = &"brenna_locket"
quest_required_item_count = 1
quest_reward_flag = &"brenna_quest_done"
quest_reward_item = &"silver_pendant"
quest_reward_item_count = 1
quest_reward_gold = 200
quest_offer_lines = PackedStringArray("...oh — you're going south, aren't you. To the road.", "Could I ask a favour? My boy Tomas — gone with the levy, two summers now — gave me a silver locket. I lost it on the path past the Outskirts. I went looking, but the goblins came back.", "If you find it on your travels — please. Bring it home.")
quest_progress_lines = PackedStringArray("If you spot a small silver locket on the Outskirts road, bring it back to me.")
quest_complete_lines = PackedStringArray("Oh — oh, you found it. Oh, child.", "Take this in return. It was Tomas's, and he'd have wanted you to wear it on the road south.")
quest_done_lines = PackedStringArray("Welcome back. The room's always warm if you need it.")

[node name="Shopkeeper" parent="." instance=ExtResource("4_npc")]
npc_name = "Garrick the Trader"
grid_position = Vector2i(15, 7)
lines = PackedStringArray("Adventurers, eh? I've potions and a few sturdy bits of gear. Care to look?")
shop_inventory = Array[StringName]([&"potion", &"hi_potion", &"ether", &"antidote", &"eye_drops", &"echo_herb", &"soft", &"phoenix_down", &"bronze_sword", &"iron_sword", &"oak_staff", &"silver_wand", &"leather_armor", &"chain_mail", &"silk_robe"])
sprite_texture = ExtResource("7_shop_tex")
quest_required_flag = &"crystal_wraith_defeated"
quest_accept_flag = &"garrick_bounty_accepted"
quest_required_kill_enemy = &"slime"
quest_required_kill_count = 5
quest_reward_flag = &"garrick_bounty_done"
quest_reward_item = &"hunters_band"
quest_reward_item_count = 1
quest_reward_gold = 500
quest_offer_lines = PackedStringArray("Hold up, I've got business if you're hunting south of the road.", "The Outskirts crawl with slimes since the cave broke open. They're eating my caravan tarpaulins. Five of the things, by my count, would be five fewer.", "Bring me five slime kills — any I can verify by the smell on your gloves — and I'll cut you a Hunter's Band and a fair price besides.")
quest_progress_lines = PackedStringArray("Five slime kills. Trust me, you'll lose count.")
quest_complete_lines = PackedStringArray("Five down, by the slime-stink alone. Good work.", "Here — Hunter's Band. Stamped by Brighthollow's bounty office. And five hundred for your trouble.")
quest_done_lines = PackedStringArray("Bounty's settled. Come back if I post another.")

