target_spawn_id = &"from_plaza"
requires_flag = &"game_complete"

[node name="Huntmaster" parent="." instance=ExtResource("4_npc")]
npc_name = "Huntmaster Roen"
grid_position = Vector2i(13, 4)
lines = PackedStringArray("I keep tally for the bounty board. The kingdom may be falling — but the work goes on.", "If you've been bringing down monsters, the office in Brighthollow knows.", "Keep your blade sharp and your kill-count higher.")
sprite_texture = ExtResource("9_villager_tex")

[node name="Townie" parent="." instance=ExtResource("4_npc")]
npc_name = "Old Hild"
grid_position = Vector2i(7, 4)
lines = PackedStringArray("There used to be a cellar under the Plaza chapel — flooded years ago when the river shifted.", "Nobody goes down there anymore. Nobody who comes back, anyway.")
sprite_texture = ExtResource("9_villager_tex")

[node name="Intro" type="Node" parent="."]
script = ExtResource("8_intro")
seen_flag = &"seen_intro"
lines = PackedStringArray("(Year 248 of the Crystal Calendar.)", "The kingdom of Auren has stood for two centuries. The Crystals that gave it life are dying.", "Crystals that once sang now wither. Towns fall silent. The king sleeps.", "Two travelers reach the last whole town.", "Aldric, a knight without a kingdom. Lyra, a scholar of forgotten magics.", "They alone know the source of the Plague — and the only way to end it.")
