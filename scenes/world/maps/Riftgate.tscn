#,,,,,,,,DD,,,,,,,,#
####################"
map_id = &"riftgate"

[node name="SpawnFromPlaza" type="Node2D" parent="."]
script = ExtResource("2_spawn")
spawn_id = &"from_plaza"
grid_position = Vector2i(9, 12)
facing = 3

[node name="ExitToPlaza" type="Node2D" parent="."]
script = ExtResource("3_warp")
grid_position = Vector2i(8, 12)
grid_size = Vector2i(2, 1)
target_map_id = &"plaza"
target_spawn_id = &"from_rift"

[node name="Riftkeeper" parent="." instance=ExtResource("6_npc")]
npc_name = "The Riftkeeper"
grid_position = Vector2i(9, 3)
lines = PackedStringArray("This is the Riftgate. Each step on the grass behind me draws a different troop from a different corner of the kingdom.", "Walk it long enough and the rifts pay you in coin and gear. Walk it too long and they take it back.")
sprite_texture = ExtResource("7_sage")

[node name="RiftLoot" type="Node2D" parent="."]
script = ExtResource("5_reward")
grid_position = Vector2i(2, 6)
sets_flag = &"rift_loot_claimed_once"
grants_gold = 8000
grants_item = &"phoenix_down"
grants_item_count = 6
speaker = "The Riftkeeper"
lines = PackedStringArray("A small purse sits on the bare floor — a gift from whichever rift you crossed last.", "(Got 6 Phoenix Downs and 8000 gold!)")
