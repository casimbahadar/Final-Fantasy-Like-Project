[node name="PyreLordTrigger" type="Node2D" parent="."]
script = ExtResource("4_encounter")
grid_position = Vector2i(9, 6)
troop_id = &"pyre_lord_boss"
defeated_flag = &"pyre_lord_defeated"
intro_lines = PackedStringArray("The marsh has been burning for a hundred years. No one set the fire. No one's putting it out.", "At its centre, on a throne of slag, sits something charred down to charcoal and crown.", "It does not stand. It does not need to.", "\"Sit, sweet things. Let me show you what slow burning looks like, on the inside.\"")
intro_speaker = "Pyre Lord"
