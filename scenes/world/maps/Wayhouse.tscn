[node name="Bram" parent="." instance=ExtResource("4_npc")]
npc_name = "Bram the Wild"
grid_position = Vector2i(2, 6)
recruit_actor_id = &"bram"
conversation_flag = &"recruited_bram"
recruit_required_flag = &"crystal_wraith_defeated"
sprite_texture = ExtResource("5_bram")
lines = PackedStringArray("Heard you killed something at the heart of the cave. Killing things is a hobby of mine. Take me along, why don't you.", "(Bram joined the party.)")
lines_after_first = PackedStringArray("My axe is your axe. The bigger the foe the better.")
recruit_locked_lines = PackedStringArray("You haven't put down anything worth following yet, friend. Come back when you have.")
quest_required_flag = &"recruited_bram"
quest_accept_flag = &"bram_quest_accepted"
quest_required_kill_enemy = &"bandit"
quest_required_kill_count = 8
quest_reward_flag = &"bram_quest_done"
quest_reward_item = &"brams_axe"
quest_reward_item_count = 1
quest_reward_gold = 1500
quest_offer_lines = PackedStringArray("One more thing. I lost an axe in a bandit ambush four winters back. Took my crew, took my axe.", "Eight bandits down — any eight, I don't care which — and I'll know the right ones got buried with it. Bring word back and the axe's yours.")
quest_progress_lines = PackedStringArray("Eight bandits. Make them count.")
quest_complete_lines = PackedStringArray("Eight, and I felt every one. Here — the axe is yours now. Took mine four winters; took yours an afternoon. Fair trade.")
quest_done_lines = PackedStringArray("Lead the way. The axe missed work.")

[node name="Wren" parent="." instance=ExtResource("4_npc")]
npc_name = "Wren of the Wood"
grid_position = Vector2i(5, 6)
recruit_actor_id = &"wren"
conversation_flag = &"recruited_wren"
recruit_required_flag = &"treant_defeated"
sprite_texture = ExtResource("9_wren")
lines = PackedStringArray("The wood listens. It said you spoke nicely to the Treant before you put it down. I'd come along, if you'll have me.", "(Wren joined the party.)")
lines_after_first = PackedStringArray("My bow draws longer than most. The wood asked me to make sure you live.")
recruit_locked_lines = PackedStringArray("The wood hasn't decided about you yet. Walk in it a while.")
quest_required_flag = &"recruited_wren"
quest_accept_flag = &"wren_quest_accepted"
quest_required_kill_enemy = &"forest_wisp"
quest_required_kill_count = 12
quest_reward_flag = &"wren_quest_done"
quest_reward_item = &"wrens_bow"
quest_reward_item_count = 1
quest_reward_gold = 1200
quest_offer_lines = PackedStringArray("My bow is in the wood somewhere — a wisp took it the night the Heart fell silent.", "Twelve wisps would even the score, and the wood would tell me which one had it.")
quest_progress_lines = PackedStringArray("Twelve wisps. The wood is patient. I am less so.")
quest_complete_lines = PackedStringArray("Twelve. The wood points west. The bow is here — it's been here all along.", "Take it. It draws longer with you holding it.")
quest_done_lines = PackedStringArray("The wood is louder when you walk through it now. Listen for it.")

[node name="Sera" parent="." instance=ExtResource("4_npc")]
npc_name = "Sera the Quiet"
grid_position = Vector2i(8, 6)
recruit_actor_id = &"sera"
conversation_flag = &"recruited_sera"
recruit_required_flag = &"wyvern_defeated"
sprite_texture = ExtResource("6_sera")
lines = PackedStringArray("You walked the high passes and a wyvern died for it. I came down because of that — I'd been waiting for someone who could.", "(Sera joined the party.)")
lines_after_first = PackedStringArray("Hands and feet do the work blades pretend to.")
recruit_locked_lines = PackedStringArray("The high passes are still living, friend. Come back to me when one of them isn't.")
quest_required_flag = &"recruited_sera"
quest_accept_flag = &"sera_quest_accepted"
quest_required_kill_enemy = &"crag_drake"
quest_required_kill_count = 6
quest_reward_flag = &"sera_quest_done"
quest_reward_item = &"seras_gauntlet"
quest_reward_item_count = 1
quest_reward_gold = 1500
quest_offer_lines = PackedStringArray("Six drakes ate my master. I left the high passes to find someone who could end six. You'll do.")
quest_progress_lines = PackedStringArray("Six drakes. The high passes will know.")
quest_complete_lines = PackedStringArray("Six. The bracer's mine again — was my master's. He'd want it on a fighter who finishes things.", "Take it. It will fit you cleanly.")
quest_done_lines = PackedStringArray("The high passes are quieter now.")

[node name="Vael" parent="." instance=ExtResource("4_npc")]
npc_name = "Vael the Listener"
grid_position = Vector2i(11, 6)
recruit_actor_id = &"vael"
conversation_flag = &"recruited_vael"
recruit_required_flag = &"hollow_king_defeated"
sprite_texture = ExtResource("7_vael")
lines = PackedStringArray("You silenced the Hollow King. The dead I read have been wanting to thank someone. They'd send me, if you'll have me.", "(Vael joined the party.)")
lines_after_first = PackedStringArray("They are louder around you, you know. They like you.")
recruit_locked_lines = PackedStringArray("The dead are still talking, child. Quiet them first, and we'll speak.")
quest_required_flag = &"recruited_vael"
quest_accept_flag = &"vael_quest_accepted"
quest_required_kill_enemy = &"courtier_ghost"
quest_required_kill_count = 10
quest_reward_flag = &"vael_quest_done"
quest_reward_item = &"vaels_grimoire"
quest_reward_item_count = 1
quest_reward_gold = 1800
quest_offer_lines = PackedStringArray("My grimoire was lost the night the Court woke. Ten courtiers later it would be in someone's hand again.")
quest_progress_lines = PackedStringArray("Ten courtiers, in any of the halls. The book remembers who held it.")
quest_complete_lines = PackedStringArray("Ten. The grimoire heard them die — every page wrote itself in the past hour.", "Take it. The dead would rather you carry it.")
quest_done_lines = PackedStringArray("They are quieter now. So am I.")

[node name="Lios" parent="." instance=ExtResource("4_npc")]
npc_name = "Lios the Wanderer"
grid_position = Vector2i(14, 6)
recruit_actor_id = &"lios"
conversation_flag = &"recruited_lios"
recruit_required_flag = &"mira_joined"
sprite_texture = ExtResource("8_lios")
lines = PackedStringArray("Sister Mira said you were the kind of folk worth a song. I write the songs after. Easier to write them with you alive — let me come.", "(Lios joined the party.)")
lines_after_first = PackedStringArray("A song needs a chorus. I prefer to be the chorus.")
recruit_locked_lines = PackedStringArray("Brighthollow's chapel hasn't sent anyone yet — and I don't follow strangers without a song between us.")
quest_required_flag = &"recruited_lios"
quest_accept_flag = &"lios_quest_accepted"
quest_required_kill_enemy = &"spectral_maiden"
quest_required_kill_count = 8
quest_reward_flag = &"lios_quest_done"
quest_reward_item = &"lios_lyre"
quest_reward_item_count = 1
quest_reward_gold = 1500
quest_offer_lines = PackedStringArray("I owe a man in Plaza a lyre. He won it off me at cards. Eight maidens of the Crypt sang the songs that wrote it — eight maidens silenced and the lyre comes home.")
quest_progress_lines = PackedStringArray("Eight maidens, eight verses. They have been singing too long.")
quest_complete_lines = PackedStringArray("Eight. They are silent. The lyre is mine again — and yours, since you gave me the silences.", "Carry it. It will hum in your pocket when you need a song.")
quest_done_lines = PackedStringArray("Every silence has a chorus. We'll find ours.")

[node name="Nyx" parent="." instance=ExtResource("4_npc")]
npc_name = "Nyx"
grid_position = Vector2i(17, 6)
recruit_actor_id = &"nyx"
conversation_flag = &"recruited_nyx"
recruit_required_flag = &"pretender_king_defeated"
sprite_texture = ExtResource("10_nyx")
lines = PackedStringArray("My contract was on the Pretender. You spoiled it. The next contract is yours — and so am I, free of charge, until it's done.", "(Nyx joined the party.)")
lines_after_first = PackedStringArray("There's always one more door we don't want to open. I open them for a living.")
recruit_locked_lines = PackedStringArray("There's a man on the throne calling himself a king. Until he isn't, we have nothing to talk about.")
quest_required_flag = &"recruited_nyx"
quest_accept_flag = &"nyx_quest_accepted"
quest_required_kill_enemy = &"hollow_twin_aldric"
quest_required_kill_count = 1
quest_reward_flag = &"nyx_quest_done"
quest_reward_item = &"nyx_dagger"
quest_reward_item_count = 1
quest_reward_gold = 2400
quest_offer_lines = PackedStringArray("My old contract — the original one, before the Pretender — was on a man who got into the Wound. The Hollow Twin wears his face now.", "End it once for me, properly. The dagger I left on his back will be free for the asking.")
quest_progress_lines = PackedStringArray("The Hollow Twin still wears his face. End him cleanly.")
quest_complete_lines = PackedStringArray("Cleanly done. The dagger came out with you, didn't it.", "Yours now. It bites the same in your hand as in mine.")
quest_done_lines = PackedStringArray("The contract closes. We'll find another.")

[node name="Calen" parent="." instance=ExtResource("4_npc")]
npc_name = "Calen the Astrologer"
grid_position = Vector2i(9, 3)
recruit_actor_id = &"calen"
conversation_flag = &"recruited_calen"
recruit_required_flag = &"game_complete"
sprite_texture = ExtResource("11_calen")
lines = PackedStringArray("The eidolons remember now. They didn't, before — they were sleeping under the seal. Now I can call them, and so can you, if you'll have me.", "(Calen joined the party.)")
lines_after_first = PackedStringArray("The eidolons don't speak words, exactly. Try Ifrit. You'll see.")
recruit_locked_lines = PackedStringArray("The seal still holds enough for me to keep my hands quiet. Come back when the king is properly dead.")
quest_required_flag = &"recruited_calen"
quest_accept_flag = &"calen_quest_accepted"
quest_required_kill_enemy = &"plague_spawn"
quest_required_kill_count = 12
quest_reward_flag = &"calen_quest_done"
quest_reward_item = &"calens_orb"
quest_reward_item_count = 1
quest_reward_gold = 3000
quest_offer_lines = PackedStringArray("My calling-orb was swallowed by a Plague Spawn at the wound's mouth. There's a dozen down there yet. End them, and one will spit it back.")
quest_progress_lines = PackedStringArray("Twelve spawn. The orb hums on its way back up.")
quest_complete_lines = PackedStringArray("Twelve. The orb came up with the last one — still warm, still humming.", "It's yours now. The eidolons answer it more cleanly when you carry it.")
quest_done_lines = PackedStringArray("The eidolons listen for you, now. They are very polite.")
