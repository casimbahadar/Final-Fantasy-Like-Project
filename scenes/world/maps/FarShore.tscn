[gd_scene load_steps=8 format=3]

[ext_resource type="Script" path="res://scripts/world/OverworldMap.gd" id="1_map"]
[ext_resource type="Script" path="res://scripts/world/SpawnPoint.gd" id="2_spawn"]
[ext_resource type="Script" path="res://scripts/world/WarpTrigger.gd" id="3_warp"]
[ext_resource type="PackedScene" path="res://scenes/world/NPC.tscn" id="4_npc"]
[ext_resource type="Texture2D" path="res://assets/sprites/placeholder/npc_innkeeper.svg" id="5_inn"]
[ext_resource type="Texture2D" path="res://assets/sprites/placeholder/npc_shopkeeper.svg" id="6_shop"]
[ext_resource type="Texture2D" path="res://assets/sprites/placeholder/npc_sage.svg" id="7_sage"]

[node name="FarShore" type="Node2D"]
y_sort_enabled = true
script = ExtResource("1_map")
grid_string = "####################
