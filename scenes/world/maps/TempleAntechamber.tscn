[node name="ChampionTrigger" type="Node2D" parent="."]
script = ExtResource("4_encounter")
grid_position = Vector2i(9, 5)
troop_id = &"skeletal_champion_mini"
defeated_flag = &"skeletal_champion_defeated"
intro_lines = PackedStringArray("In the temple's outer hall, a knight in plate stands at attention before the inner door — not undead so much as patient. Very patient.", "It lifts a greatsword that has not been moved in two hundred years. The metal sings faintly.", "\"...the king's sleep is sacred. Pass me first.\"")
intro_speaker = "Skeletal Champion"
