[node name="StormwyrmTrigger" type="Node2D" parent="."]
script = ExtResource("4_encounter")
grid_position = Vector2i(9, 5)
troop_id = &"stormwyrm_boss"
defeated_flag = &"stormwyrm_defeated"
intro_lines = PackedStringArray("Wind tears through the broken aerie. Lightning glances off cold stone.", "Then it lifts — slow, vast, scaled the colour of the storm itself.", "The Stormwyrm fixes a single yellow eye on you, and somewhere far below, the world holds its breath.", "\"...little one. So you reached me.\"", "\"Then sing.\"")
intro_speaker = "Stormwyrm"

[node name="EndingMonument" type="Node2D" parent="."]
script = ExtResource("5_story")
grid_position = Vector2i(9, 3)
requires_flag = &"stormwyrm_defeated"
sets_flag = &"chapter_4_complete"
warp_target_map = &"tidal_reef"
warp_target_spawn = &"from_aerie"
speaker = "The Wind"
lines = PackedStringArray("As the Stormwyrm settles, the wind takes on a softer voice — almost a song.", "Across Auren, the dimming Crystals flicker. Some catch. A few — far below — begin to glow again.", "Tessera kneels beside the great wyrm and lays a hand on its skull. \"Sleep,\" she murmurs. \"You did your work.\"", "Three roots, cut.", "But the wind does not stop singing — and Mira's eyes are open, and they are afraid.", "\"...something else is awake. The seal is gone, and something the Plague was holding back is loose.\"", "Lyra looks east, where the cliffs fall away to a black coast.", "\"Then we go to it. Down to the coast first.\"")
lines_locked = PackedStringArray("The wind howls. There is nothing more to be said until the Wyrm is dealt with.")
