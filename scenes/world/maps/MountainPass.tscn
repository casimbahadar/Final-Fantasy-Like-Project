[node name="Tessera" parent="." instance=ExtResource("4_npc")]
npc_name = "Tessera"
grid_position = Vector2i(7, 6)
lines = PackedStringArray("A figure in pale blue armor stands at the trailhead, spear planted.", "\"You're the ones the Crystal Heart sang for, then. The wind told me you'd come.\"", "\"My queen sent me to deal with the Storm — but I came too late, or too early. Either way, I'm the wrong number alone.\"", "\"Five against a Wyrm, though. That sounds about right.\"", "(Tessera the Dragoon has joined the party!)")
lines_after_first = PackedStringArray("Up the pass. Don't dawdle — the wind shifts.")
