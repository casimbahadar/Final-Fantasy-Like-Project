[node name="BossTrigger" type="Node2D" parent="."]
script = ExtResource("4_encounter")
grid_position = Vector2i(10, 6)
troop_id = &"crystal_wraith_boss"
defeated_flag = &"crystal_wraith_defeated"
intro_lines = PackedStringArray("A figure of robe and crystal turns to face you.", "\"You... you would steal what gives this land its breath?\"", "\"Then come, doomed ones — let the Plague have its keepers!\"")
intro_speaker = "Crystal Wraith"

[node name="EndingCrystal" type="Node2D" parent="."]
script = ExtResource("5_story")
grid_position = Vector2i(17, 6)
requires_flag = &"crystal_wraith_defeated"
sets_flag = &"chapter_2_started"
recruit_actor_id = &"kael"
warp_target_map = &"forest_path"
warp_target_spawn = &"from_cave"
speaker = "Crystal Heart"
lines = PackedStringArray("As the Wraith fades, the heart-crystal pulses with a sluggish, dim light.", "A figure steps from behind a stalagmite — Kael, a rogue you'd half-glimpsed in the plaza.", "\"The Plague's source isn't this cave,\" Kael says. \"It's deeper. Older. Out past the Whispering Wood.\"", "\"I'll come with you. I owe the Heart that much.\"", "Kael has joined the party!", "A new path opens to the north.")
lines_locked = PackedStringArray("The crystal pulses faintly. Something blocks its full light.")
