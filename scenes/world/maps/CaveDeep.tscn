grid_position = Vector2i(2, 6)
facing = 2

[node name="ExitToEntrance" type="Node2D" parent="."]
script = ExtResource("3_warp")
grid_position = Vector2i(1, 6)
grid_size = Vector2i(1, 1)
target_map_id = &"cave_entrance"
