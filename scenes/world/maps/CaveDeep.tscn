[node name="BossTrigger" type="Node2D" parent="."]
script = ExtResource("4_encounter")
grid_position = Vector2i(10, 6)
troop_id = &"crystal_wraith_boss"
defeated_flag = &"crystal_wraith_defeated"
intro_lines = PackedStringArray("A figure of robe and crystal turns to face you.", "\"You... you would steal what gives this land its breath?\"", "\"Then come, doomed ones — let the Plague have its keepers!\"")
intro_speaker = "Crystal Wraith"

[node name="EndingCrystal" type="Node2D" parent="."]
script = ExtResource("5_ending")
grid_position = Vector2i(17, 6)
requires_flag = &"crystal_wraith_defeated"
speaker = "Crystal Heart"
lines = PackedStringArray("Aldric and Lyra place their hands upon the heart of the cavern.", "Light spreads outward — slowly at first, then in a rush.", "Across the kingdom, withered crystals begin to bloom anew.", "The Plague is over. The road back will be long.", "But for now — the silence after a song.", "", "— END OF DEMO —", "Press confirm to return to the title.")

[node name="EndingSprite" type="Sprite2D" parent="EndingCrystal"]
texture_filter = 1
position = Vector2(8, 0)
texture = ExtResource("6_crystal")
