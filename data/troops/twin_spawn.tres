[gd_resource type="Resource" script_class="Troop" load_steps=5 format=3]

[ext_resource type="Script" path="res://scripts/resources/Troop.gd" id="1_script"]
[ext_resource type="Script" path="res://scripts/resources/TroopMember.gd" id="2_member"]
[ext_resource type="Resource" path="res://data/enemies/doppelganger.tres" id="3_twin"]
[ext_resource type="Resource" path="res://data/enemies/plague_spawn.tres" id="4_spawn"]

[sub_resource type="Resource" id="Member1"]
script = ExtResource("2_member")
