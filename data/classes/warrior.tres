[resource]
script = ExtResource("1_script")
id = &"warrior"
display_name = "Warrior"
description = "Front-line fighter. High HP and physical attack."
learnset = Array[Resource]([SubResource("LearnAttack"), SubResource("LearnPower"), SubResource("LearnWall"), SubResource("LearnProvoke"), SubResource("LearnCleave")])
xp_curve = PackedInt32Array()
