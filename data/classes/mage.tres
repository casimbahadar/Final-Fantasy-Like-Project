[gd_resource type="Resource" script_class="CharClass" load_steps=10 format=3]

[ext_resource type="Script" path="res://scripts/resources/CharClass.gd" id="1_script"]
[ext_resource type="Script" path="res://scripts/resources/LearnEntry.gd" id="2_learn"]
[ext_resource type="Resource" path="res://data/skills/attack.tres" id="3_attack"]
[ext_resource type="Resource" path="res://data/skills/fire.tres" id="4_fire"]
[ext_resource type="Resource" path="res://data/skills/cure.tres" id="5_cure"]
[ext_resource type="Resource" path="res://data/skills/sleep.tres" id="6_sleep"]
[ext_resource type="Resource" path="res://data/skills/blizzard.tres" id="7_blizzard"]
[ext_resource type="Resource" path="res://data/skills/haste.tres" id="8_haste"]
[ext_resource type="Resource" path="res://data/skills/slow.tres" id="9_slow"]

[sub_resource type="Resource" id="LearnAttack"]
script = ExtResource("2_learn")
level = 1
skill = ExtResource("3_attack")

[sub_resource type="Resource" id="LearnFire"]
script = ExtResource("2_learn")
level = 1
skill = ExtResource("4_fire")

[sub_resource type="Resource" id="LearnCure"]
script = ExtResource("2_learn")
level = 3
skill = ExtResource("5_cure")

[sub_resource type="Resource" id="LearnSleep"]
script = ExtResource("2_learn")
level = 4
skill = ExtResource("6_sleep")

[sub_resource type="Resource" id="LearnBlizzard"]
script = ExtResource("2_learn")
level = 5
skill = ExtResource("7_blizzard")

[sub_resource type="Resource" id="LearnHaste"]
script = ExtResource("2_learn")
level = 7
skill = ExtResource("8_haste")

[sub_resource type="Resource" id="LearnSlow"]
script = ExtResource("2_learn")
level = 8
skill = ExtResource("9_slow")

[resource]
script = ExtResource("1_script")
id = &"mage"
display_name = "Mage"
description = "Arcane caster. Low HP, high magic. Learns spells with level."
learnset = Array[Resource]([SubResource("LearnAttack"), SubResource("LearnFire"), SubResource("LearnCure"), SubResource("LearnSleep"), SubResource("LearnBlizzard"), SubResource("LearnHaste"), SubResource("LearnSlow")])
xp_curve = PackedInt32Array()
