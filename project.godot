; Engine configuration file.
; Open this folder in Godot 4.2+ to edit/run the project.

config_version=5

[application]

config/name="Final Fantasy Like Project"
config/description="A Final Fantasy-inspired JRPG built in Godot 4. Targets itch.io (Web), Android, and iOS."
run/main_scene="res://scenes/ui/TitleScreen.tscn"
config/features=PackedStringArray("4.2", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

Database="*res://scripts/globals/Database.gd"
GameState="*res://scripts/globals/GameState.gd"
Party="*res://scripts/globals/Party.gd"
SaveSystem="*res://scripts/globals/SaveSystem.gd"
AudioManager="*res://scripts/globals/AudioManager.gd"
SceneRouter="*res://scripts/globals/SceneRouter.gd"

[display]

window/size/viewport_width=480
window/size/viewport_height=270
window/size/window_width_override=960
window/size/window_height_override=540
window/stretch/mode="viewport"
window/stretch/aspect="keep"
window/handheld/orientation=0

